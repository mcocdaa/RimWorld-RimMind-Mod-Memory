<?xml version="1.0" encoding="utf-8"?>
<ModMetaData>
    <name>RimMind - Memory</name>
    <author>mcocdaa</author>
    <packageId>mcocdaa.RimMindMemory</packageId>
    <supportedVersions>
        <li>1.6</li>
    </supportedVersions>
    <description>Three-layer memory system for AI mods. Tracks colonist activities and map events, providing temporal context for AI evaluations. Features Active/Archive/Dark memory layers, work session aggregation, narrator memory, and importance decay.</description>
    <modDependencies>
        <li>
            <packageId>brrainz.harmony</packageId>
            <displayName>Harmony</displayName>
            <steamWorkshopUrl>steam://url/CommunityFilePage/2009463077</steamWorkshopUrl>
        </li>
        <li>
            <packageId>mcocdaa.RimMindCore</packageId>
            <displayName>RimMind - Core</displayName>
            <downloadUrl>https://github.com/mcocdaa/RimMind-Core</downloadUrl>
        </li>
    </modDependencies>
    <loadAfter>
        <li>brrainz.harmony</li>
        <li>mcocdaa.RimMindCore</li>
    </loadAfter>
</ModMetaData>
